# --- App ---
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Database (Prisma + Postgres) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/restaurant?schema=public"

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- ready2order POS ---
R2O_BASE_URL=https://api.ready2order.com/v1
R2O_API_KEY=your-ready2order-account-token

# --- Thermal printer (ESC/POS) ---
# PRINTER_TYPE: epson | star
PRINTER_TYPE=epson
# Network printer: tcp://IP:9100   USB: printer:auto
PRINTER_INTERFACE=tcp://192.168.1.50:9100
PRINTER_ENABLED=false

# --- Restaurant info (printed on ticket) ---
RESTAURANT_NAME="Tarantella Pizza Pasta Napoli"
RESTAURANT_ADDRESS="Sonnenweg 11, 8793 Trofaiach"
RESTAURANT_PHONE="+43 676 632 86 77"

# --- Google Maps (Geocoding, Distance Matrix, checkout map) ---
# Enable in Google Cloud: Maps JavaScript API, Geocoding API, Distance Matrix API, Places API, Directions API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Google reCAPTCHA (contact form) ---
# Version: v2 = checkbox "Ich bin kein Roboter"  |  v3 = invisible (no checkbox)
RECAPTCHA_VERSION=v2
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
